+                enabled: node.index <= save.unlockedNodeIndex,
+                onTap: node.index <= save.unlockedNodeIndex
+                    ? () => Navigator.of(context).push(
+                          MaterialPageRoute(builder: (_) => DuelScreen(node: node)),
+                        )
+                    : null,
+              ),
+            ),
+        ],
+      ),
+    );
+  }
+}
