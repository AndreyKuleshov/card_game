+  final DuelConfig opponentConfig;
+  final bool isBoss;
+  final String? rewardTrumpId;
+
+  const MapNode({
+    required this.index,
+    required this.title,
+    required this.opponentCardIds,
+    required this.opponentConfig,
+    this.isBoss = false,
+    this.rewardTrumpId,
+  });
